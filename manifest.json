{
  "manifest_version": 3,
  "name": "Local Bookmark Admin",
  "description": "A local popup bookmark manager backed by Chrome bookmarks.",
  "version": "0.3.7",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/app-icon/icon16.png",
    "32": "assets/app-icon/icon32.png",
    "48": "assets/app-icon/icon48.png",
    "128": "assets/app-icon/icon128.png"
  },
  "permissions": [
    "bookmarks",
    "contextMenus",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Save page to Bookmark Admin",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/app-icon/icon16.png",
      "32": "assets/app-icon/icon32.png",
      "48": "assets/app-icon/icon48.png",
      "128": "assets/app-icon/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/*.svg",
        "assets/illustrations/*.svg",
        "assets/app-icon/*.png"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "commands": {
    "quick-save-current-page": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Save the current page"
    },
    "open-bookmark-admin": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "Open Bookmark Admin"
    }
  }
}
